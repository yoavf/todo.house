#!/bin/sh

echo "🔍 Running pre-commit checks..."

# Run Biome auto-fix
echo "🔧 Auto-fixing code with Biome..."
pnpm run lint:fix
if [ $? -ne 0 ]; then
  echo "❌ Biome auto-fix failed. Please check the errors."
  exit 1
fi

# Add any fixed files to the commit
git add -u

# Run tests
echo "🧪 Running tests..."
pnpm test
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Please fix the failing tests before committing."
  exit 1
fi

echo "✅ All pre-commit checks passed!"
